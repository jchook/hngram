# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_DATABASE=hn_ngram

# Password: use CLICKHOUSE_PASSWORD for dev, CLICKHOUSE_PASSWORD_FILE for prod
#CLICKHOUSE_PASSWORD=
#CLICKHOUSE_PASSWORD_FILE=/run/secrets/clickhouse_password

# API
API_PORT=3000
API_HOST=0.0.0.0

# Pruning (defaults: 2gram=20, 3gram=10)
#PRUNE_MIN_2GRAM_GLOBAL=20
#PRUNE_MIN_3GRAM_GLOBAL=10
#PRUNE_MIN_2GRAM_BUCKET=3
#PRUNE_MIN_3GRAM_BUCKET=5

# Environment
RUST_LOG=info
