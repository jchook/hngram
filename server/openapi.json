{
  "openapi": "3.1.0",
  "info": {
    "title": "api",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ngram": {
      "get": {
        "tags": [],
        "operationId": "ngram",
        "parameters": [
          {
            "name": "phrase",
            "in": "query",
            "description": "Single phrase to query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start date (YYYY-MM-DD). Default: 2011-01-01",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date (YYYY-MM-DD). Default: today",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "granularity",
            "in": "query",
            "description": "Time granularity: day, week, month, year. Default: month",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Query result for a single phrase",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorDetail": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "version",
          "tokenizer_version"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "tokenizer_version": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "Point": {
        "type": "object",
        "required": [
          "t",
          "v",
          "count",
          "total"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "format": "int64",
            "description": "Raw occurrence count for this phrase in this bucket",
            "minimum": 0
          },
          "t": {
            "type": "string",
            "description": "Bucket timestamp (YYYY-MM-DD)"
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "Total n-grams of this order in this bucket",
            "minimum": 0
          },
          "v": {
            "type": "number",
            "format": "double",
            "description": "Relative frequency (count / total_count)"
          }
        }
      },
      "QueryMeta": {
        "type": "object",
        "required": [
          "tokenizer_version",
          "start",
          "end",
          "granularity"
        ],
        "properties": {
          "end": {
            "type": "string"
          },
          "granularity": {
            "type": "string"
          },
          "start": {
            "type": "string"
          },
          "tokenizer_version": {
            "type": "string"
          }
        }
      },
      "QueryParams": {
        "type": "object",
        "description": "Query a single phrase's n-gram frequency over time.\nThe client makes one request per phrase (up to MAX_PHRASES in parallel).",
        "required": [
          "phrase"
        ],
        "properties": {
          "end": {
            "type": [
              "string",
              "null"
            ],
            "description": "End date (YYYY-MM-DD). Default: today"
          },
          "granularity": {
            "type": [
              "string",
              "null"
            ],
            "description": "Time granularity: day, week, month, year. Default: month"
          },
          "phrase": {
            "type": "string",
            "description": "Single phrase to query"
          },
          "start": {
            "type": [
              "string",
              "null"
            ],
            "description": "Start date (YYYY-MM-DD). Default: 2011-01-01"
          }
        }
      },
      "QueryResponse": {
        "type": "object",
        "required": [
          "phrase",
          "normalized",
          "status",
          "points",
          "global_count",
          "meta"
        ],
        "properties": {
          "global_count": {
            "type": "integer",
            "format": "int64",
            "description": "Total occurrences of this phrase across all time",
            "minimum": 0
          },
          "meta": {
            "$ref": "#/components/schemas/QueryMeta"
          },
          "normalized": {
            "type": "string",
            "description": "Normalized/tokenized form used for lookup"
          },
          "phrase": {
            "type": "string",
            "description": "Original phrase from input"
          },
          "points": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Point"
            },
            "description": "Sparse data points (only non-zero buckets). Client handles zero-fill."
          },
          "status": {
            "$ref": "#/components/schemas/SeriesStatus",
            "description": "Status of this phrase"
          }
        }
      },
      "SeriesStatus": {
        "type": "string",
        "enum": [
          "indexed",
          "not_indexed",
          "invalid"
        ]
      }
    }
  }
}