{
  "openapi": "3.1.0",
  "info": {
    "title": "api",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/feedback": {
      "post": {
        "tags": [],
        "operationId": "feedback",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedbackRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Feedback recorded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedbackResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid feedback request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/freshness": {
      "get": {
        "tags": [],
        "operationId": "freshness",
        "responses": {
          "200": {
            "description": "Data freshness info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FreshnessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ngram": {
      "get": {
        "tags": [],
        "operationId": "ngram",
        "parameters": [
          {
            "name": "phrase",
            "in": "query",
            "description": "Single phrase to query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "rust programming"
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start date (YYYY-MM-DD). Default: 2011-01-01",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            },
            "example": "2020-01-01"
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date (YYYY-MM-DD). Default: today",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            },
            "example": "2024-12-01"
          },
          {
            "name": "granularity",
            "in": "query",
            "description": "Time granularity: day, week, month, year. Default: month",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            },
            "example": "month"
          }
        ],
        "responses": {
          "200": {
            "description": "Query result for a single phrase",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorDetail": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "example": "INVALID_DATE_FORMAT"
          },
          "message": {
            "type": "string",
            "example": "Invalid start date '2020/01/01', expected YYYY-MM-DD"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "example": {
          "error": {
            "code": "INVALID_DATE_FORMAT",
            "message": "Invalid start date '2020/01/01', expected YYYY-MM-DD"
          }
        }
      },
      "FeedbackRequest": {
        "type": "object",
        "description": "Anonymous user feedback that a multi-phrase comparison was interesting.\nOne row per thumbs-up; no rating field — submission itself is the signal.",
        "required": [
          "phrases",
          "granularity",
          "start",
          "smoothing"
        ],
        "properties": {
          "granularity": {
            "type": "string",
            "example": "month"
          },
          "phrases": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Phrases the user was viewing when they hit thumbs-up (≥2 expected).",
            "example": [
              "rust",
              "go"
            ]
          },
          "smoothing": {
            "type": "integer",
            "format": "int32",
            "example": 0,
            "minimum": 0
          },
          "start": {
            "type": "string",
            "example": "2011-01-01"
          }
        }
      },
      "FeedbackResponse": {
        "type": "object",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "FreshnessResponse": {
        "type": "object",
        "required": [
          "tokenizer_version"
        ],
        "properties": {
          "last_ingested_date": {
            "type": [
              "string",
              "null"
            ],
            "description": "Date of the most recent comment ingested (YYYY-MM-DD), or null if no data.",
            "example": "2026-04-30"
          },
          "last_ingested_ts": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Unix timestamp in milliseconds for the most recent comment ingested, or null.",
            "example": 1745977200000
          },
          "tokenizer_version": {
            "type": "string",
            "example": "1"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "version",
          "tokenizer_version"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "tokenizer_version": {
            "type": "string",
            "example": "1"
          },
          "version": {
            "type": "string",
            "example": "0.1.0"
          }
        }
      },
      "Point": {
        "type": "object",
        "required": [
          "t",
          "v",
          "count",
          "total"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "format": "int64",
            "description": "Raw occurrence count for this phrase in this bucket",
            "example": 187,
            "minimum": 0
          },
          "t": {
            "type": "string",
            "description": "Bucket timestamp (YYYY-MM-DD)",
            "example": "2024-06-01"
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "Total n-grams of this order in this bucket",
            "example": 1245836,
            "minimum": 0
          },
          "v": {
            "type": "number",
            "format": "double",
            "description": "Relative frequency (count / total_count)",
            "example": 0.0001501
          }
        }
      },
      "QueryMeta": {
        "type": "object",
        "required": [
          "tokenizer_version",
          "start",
          "end",
          "granularity"
        ],
        "properties": {
          "end": {
            "type": "string",
            "example": "2024-12-01"
          },
          "granularity": {
            "type": "string",
            "example": "month"
          },
          "start": {
            "type": "string",
            "example": "2020-01-01"
          },
          "tokenizer_version": {
            "type": "string",
            "example": "1"
          }
        }
      },
      "QueryParams": {
        "type": "object",
        "description": "Query a single phrase's n-gram frequency over time.\nThe client makes one request per phrase (up to MAX_PHRASES in parallel).",
        "required": [
          "phrase"
        ],
        "properties": {
          "end": {
            "type": [
              "string",
              "null"
            ],
            "description": "End date (YYYY-MM-DD). Default: today"
          },
          "granularity": {
            "type": [
              "string",
              "null"
            ],
            "description": "Time granularity: day, week, month, year. Default: month"
          },
          "phrase": {
            "type": "string",
            "description": "Single phrase to query"
          },
          "start": {
            "type": [
              "string",
              "null"
            ],
            "description": "Start date (YYYY-MM-DD). Default: 2011-01-01"
          }
        }
      },
      "QueryResponse": {
        "type": "object",
        "required": [
          "phrase",
          "normalized",
          "status",
          "points",
          "global_count",
          "meta"
        ],
        "properties": {
          "global_count": {
            "type": "integer",
            "format": "int64",
            "description": "Total occurrences of this phrase across all time",
            "minimum": 0
          },
          "meta": {
            "$ref": "#/components/schemas/QueryMeta"
          },
          "normalized": {
            "type": "string",
            "description": "Normalized/tokenized form used for lookup"
          },
          "phrase": {
            "type": "string",
            "description": "Original phrase from input"
          },
          "points": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Point"
            },
            "description": "Sparse data points (only non-zero buckets). Client handles zero-fill."
          },
          "status": {
            "$ref": "#/components/schemas/SeriesStatus",
            "description": "Status of this phrase"
          }
        },
        "example": {
          "global_count": 18432,
          "meta": {
            "end": "2024-12-01",
            "granularity": "month",
            "start": "2020-01-01",
            "tokenizer_version": "1"
          },
          "normalized": "rust programming",
          "phrase": "rust programming",
          "points": [
            {
              "count": 98,
              "t": "2020-01-01",
              "total": 1206897,
              "v": 0.0000812
            },
            {
              "count": 124,
              "t": "2020-07-01",
              "total": 1199226,
              "v": 0.0001034
            },
            {
              "count": 159,
              "t": "2021-01-01",
              "total": 1218391,
              "v": 0.0001305
            },
            {
              "count": 187,
              "t": "2024-06-01",
              "total": 1245836,
              "v": 0.0001501
            }
          ],
          "status": "indexed"
        }
      },
      "SeriesStatus": {
        "type": "string",
        "enum": [
          "indexed",
          "not_indexed",
          "invalid"
        ],
        "example": "indexed"
      }
    }
  }
}