{
    # Global options
    admin off
    order rate_limit before basicauth
}

:80 {
    # Rate limit API: 120 requests/min per IP.
    # Bypassed for loopback and for requests carrying a valid loadtest token.
    # Token is read from the LOADTEST_TOKEN env var; the default value below is
    # a sentinel that no real client would send, so the bypass is closed unless
    # the operator deliberately sets the env var. See loadtest/README.md.
    rate_limit {
        zone api_limit {
            match {
                path /api/*
                not {
                    remote_ip 127.0.0.1/32 ::1/128
                }
                not {
                    header X-Loadtest-Token {$LOADTEST_TOKEN:loadtest-disabled-do-not-use}
                }
            }
            key {remote_host}
            events 120
            window 1m
        }
    }

    # Proxy API requests to backend (Cache-Control set by API)
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:3000
    }

    # Proxy Scalar API explorer
    handle /scalar* {
        reverse_proxy api:3000
    }

    # Serve static frontend (SPA fallback)
    handle {
        root * /srv
        try_files {path} /index.html
        file_server

        # Cache static assets with long TTL + immutable
        @static path *.js *.css *.png *.jpg *.svg *.woff2 *.ico
        header @static Cache-Control "public, max-age=31536000, immutable"
    }

    # Compression
    encode gzip

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
}
