{
    # Global options
    admin off
    order rate_limit before basicauth
}

:80 {
    # Rate limit API: 120 requests/min per IP
    rate_limit {
        zone api_limit {
            match {
                path /api/*
            }
            key {remote_host}
            events 120
            window 1m
        }
    }

    # Serve static frontend
    root * /srv
    file_server

    # Proxy API requests to backend (Cache-Control set by API)
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:3000
    }

    # Cache static assets (JS/CSS/images) with long TTL + immutable
    @static path *.js *.css *.png *.jpg *.svg *.woff2 *.ico
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Also proxy OpenAPI spec and Swagger UI
    handle /swagger-ui* {
        reverse_proxy api:3000
    }

    handle /api-doc/* {
        reverse_proxy api:3000
    }

    # SPA fallback - serve index.html for client-side routing
    try_files {path} /index.html

    # Compression
    encode gzip

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
}
