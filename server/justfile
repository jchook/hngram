set positional-arguments

ingest *args="download":
  cargo run -p ingestion -- "$@"

ingest-dev *args="":
  cargo run -p ingestion -- process --output parquet --config ingestion.dev.toml "$@"

ingest-test *args="":
  cargo run -p ingestion -- process --output parquet --config ingestion.test.toml "$@"

up:
  watchexec -r -w crates -- cargo run -p api --bin api

test:
  cargo test

openapi:
  cargo run -p api --bin generate_openapi > openapi.json
