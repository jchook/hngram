set positional-arguments

ingest *args="download":
  cargo run -p ingestion -- "$@"

ingest-dev:
  cargo run -p ingestion -- process --config ingestion.dev.toml "$@"

ingest-test:
  cargo run -p ingestion -- process --config ingestion.test.toml "$@"

import *args="":
  cargo run -p ingestion -- import "$@"

up:
  watchexec -r -w crates -- cargo run -p api --bin api

test:
  cargo test

openapi:
  cargo run -p api --bin generate_openapi > openapi.json
